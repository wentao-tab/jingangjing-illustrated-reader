<script>
	// @ts-nocheck
	const chapterMeta = Array.from(document.querySelectorAll("[data-chapter-target]")).map((button) => ({
		chapter: Number(button.dataset.chapterTarget),
		title: button.querySelector("strong")?.textContent?.trim() ?? "",
	}));
	const chapters = [...document.querySelectorAll("[data-chapter-panel]")];
	const sourcePanels = [...document.querySelectorAll("[data-source-panel]")];
	const chapterButtons = [...document.querySelectorAll("[data-chapter-target]")];
	const selects = [...document.querySelectorAll("[data-chapter-select]")];
	const cardButtons = [...document.querySelectorAll("[data-open-card]")];
	const sourceToggle = document.querySelector("[data-source-toggle]");
	const cardView = document.querySelector('[data-reader-view="cards"]');
	const sourceView = document.querySelector('[data-reader-view="source"]');
	const lightbox = document.querySelector("[data-lightbox]");
	const railTitle = document.querySelector("[data-rail-title]");
	const sutraAudio = document.querySelector("[data-sutra-audio]");
	const audioToggle = document.querySelector("[data-audio-toggle]");
	const audioState = document.querySelector("[data-audio-state]");
	let activeChapter = 1;
	let activeCard = 0;
	let sourceMode = false;

	function showChapter(next) {
		const clamped = Math.max(1, Math.min(chapters.length, Number(next)));
		activeChapter = clamped;
		chapters.forEach((panel) => panel.classList.toggle("active", Number(panel.dataset.chapterPanel) === clamped));
		sourcePanels.forEach((panel) => panel.classList.toggle("active", Number(panel.dataset.sourcePanel) === clamped));
		chapterButtons.forEach((button) => button.classList.toggle("active", Number(button.dataset.chapterTarget) === clamped));
		selects.forEach((select) => (select.value = String(clamped)));
		const current = chapterMeta.find((item) => item.chapter === clamped);
		if (railTitle && current) railTitle.textContent = `第 ${String(clamped).padStart(2, "0")} 品 · ${current.title}`;
		window.scrollTo({ top: 0, behavior: "smooth" });
	}

	function setReaderMode(nextSourceMode) {
		sourceMode = Boolean(nextSourceMode);
		document.body.classList.toggle("sutra-source-mode", sourceMode);
		sourceToggle?.setAttribute("aria-pressed", String(sourceMode));
		if (sourceToggle) sourceToggle.textContent = sourceMode ? "配图阅读" : "原文来源";
		if (cardView) cardView.hidden = sourceMode;
		if (sourceView) sourceView.hidden = !sourceMode;
		showChapter(activeChapter);
	}

	function setLightboxFromButton(button) {
		activeChapter = Number(button.dataset.chapter);
		activeCard = Number(button.dataset.index);
		showChapter(activeChapter);
		document.querySelector("[data-lightbox-title]").textContent = button.dataset.title;
		document.querySelector("[data-lightbox-sentence]").textContent = button.dataset.sentence;
		document.querySelector("[data-lightbox-plain]").textContent = button.dataset.plain;
		document.querySelector("[data-lightbox-prompt]").textContent = button.dataset.prompt;
		const art = document.querySelector("[data-lightbox-art]");
		art.className = `lightbox-art fallback-${activeCard % 5}`;
		art.style.backgroundImage = "";
		if (button.dataset.image) {
			art.classList.add("has-image");
			art.style.backgroundImage = `url("${button.dataset.image}")`;
		}
		lightbox.hidden = false;
		document.body.classList.add("sutra-lightbox-open");
	}

	function setAudioPlaying(isPlaying) {
		document.body.classList.toggle("sutra-audio-playing", isPlaying);
		document.body.classList.remove("sutra-audio-blocked");
		audioToggle?.setAttribute("aria-pressed", String(isPlaying));
		audioToggle?.setAttribute("aria-label", isPlaying ? "暂停诵读音频" : "播放诵读音频");
		if (audioState) audioState.textContent = isPlaying ? "播放中" : "点击播放";
	}

	function setAudioBlocked(error) {
		document.body.classList.remove("sutra-audio-playing");
		document.body.classList.add("sutra-audio-blocked");
		audioToggle?.setAttribute("aria-pressed", "false");
		if (audioToggle && error) audioToggle.dataset.audioError = error.name ?? "play-error";
		if (audioState) audioState.textContent = "再点一次";
	}

	chapterButtons.forEach((button) => button.addEventListener("click", () => showChapter(button.dataset.chapterTarget)));
	selects.forEach((select) => select.addEventListener("change", () => showChapter(select.value)));
	sourceToggle?.addEventListener("click", () => setReaderMode(!sourceMode));
	document.querySelectorAll("[data-move]").forEach((button) => {
		button.addEventListener("click", () => showChapter(activeChapter + Number(button.dataset.move)));
	});
	cardButtons.forEach((button) => button.addEventListener("click", () => setLightboxFromButton(button)));
	audioToggle?.addEventListener("click", async () => {
		if (!sutraAudio) return;
		if (sutraAudio.paused) {
			try {
				if (sutraAudio.readyState === 0) sutraAudio.load();
				await sutraAudio.play();
			} catch (error) {
				setAudioBlocked(error);
			}
		} else {
			sutraAudio.pause();
		}
	});
	sutraAudio?.addEventListener("play", () => setAudioPlaying(true));
	sutraAudio?.addEventListener("pause", () => setAudioPlaying(false));
	sutraAudio?.addEventListener("ended", () => setAudioPlaying(false));
	document.querySelector("[data-close-lightbox]")?.addEventListener("click", () => {
		lightbox.hidden = true;
		document.body.classList.remove("sutra-lightbox-open");
	});
	document.querySelectorAll("[data-lightbox-move]").forEach((button) => {
		button.addEventListener("click", () => {
			const currentGlobalIndex = cardButtons.findIndex((item) => Number(item.dataset.chapter) === activeChapter && Number(item.dataset.index) === activeCard);
			const nextGlobalIndex = Math.max(0, Math.min(cardButtons.length - 1, currentGlobalIndex + Number(button.dataset.lightboxMove)));
			setLightboxFromButton(cardButtons[nextGlobalIndex]);
		});
	});
	lightbox?.addEventListener("click", (event) => {
		if (event.target === lightbox) {
			lightbox.hidden = true;
			document.body.classList.remove("sutra-lightbox-open");
		}
	});
	window.addEventListener("keydown", (event) => {
		if (event.key === "Escape" && !lightbox.hidden) {
			lightbox.hidden = true;
			document.body.classList.remove("sutra-lightbox-open");
		}
	});
</script>

