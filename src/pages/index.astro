---
import MainHead from "../components/MainHead.astro";
import { withBase } from "../utils/paths";
import diamondSutraData from "../data/diamond-sutra.json";

const repoUrl = "https://github.com/wentao-tab/jingangjing-illustrated-reader";

const chapterTitles = [
	"法会因由分",
	"善现启请分",
	"大乘正宗分",
	"妙行无住分",
	"如理实见分",
	"正信希有分",
	"无得无说分",
	"依法出生分",
	"一相无相分",
	"庄严净土分",
	"无为福胜分",
	"尊重正教分",
	"如法受持分",
	"离相寂灭分",
	"持经功德分",
	"能净业障分",
	"究竟无我分",
	"一体同观分",
	"法界通化分",
	"离色离相分",
	"非说所说分",
	"无法可得分",
	"净心行善分",
	"福智无比分",
	"化无所化分",
	"法身非相分",
	"无断无灭分",
	"不受不贪分",
	"威仪寂静分",
	"一合理相分",
	"知见不生分",
	"应化非真分",
];

const chapterNotes = [
	["如是我闻，一时，佛在舍卫国祗树给孤独园，与大比丘众千二百五十人俱。", "故事从一次法会现场开始：佛与大众同在祇树给孤独园。", "祇园清晨，僧众安静入座，阳光落在钵盂与树影之间。"],
	["云何应住？云何降伏其心？", "须菩提替所有想修行的人问出核心问题：心到底安放在哪里。", "长者合掌请问，庭院一角的水面映出不安的心。"],
	["应如是降伏其心。所有一切众生之类，我皆令入无余涅槃而灭度之。", "发愿度众生，但不把众生、功劳和自我抓成实有。", "渡口薄雾中，行人过桥，摆渡者不留下姓名。"],
	["菩萨于法，应无所住，行于布施。", "给予可以很认真，但心不要住在回报、身份和功德账本里。", "一只手递出灯火，另一只手没有索取，背景是安静街巷。"],
	["凡所有相，皆是虚妄。若见诸相非相，即见如来。", "所有外相都不是最后答案；能看见相的松动，才接近真实。", "铜镜照见花影，镜面微微起雾，人物站在光外。"],
	["信心清净，则生实相。", "真正的信不是迷信，而是心清净到不再被表象拖走。", "竹林中一束清光穿过尘埃，年轻行者停下脚步。"],
	["如来所说法，皆不可取、不可说，非法、非非法。", "法是渡河的筏，不是拿来收藏和争论的标签。", "河岸边一只竹筏停靠，远处有人已上岸回望。"],
	["一切诸佛，及诸佛阿耨多罗三藐三菩提法，皆从此经出。", "这部经的价值在于它不断把人从执着里松开。", "古旧经卷在桌上展开，字迹之外是辽阔山水。"],
	["须陀洹名为入流，而无所入。", "修行不是获得一个更高级的身份，而是少一点自我占有。", "溪流入江，没有牌匾，只有水纹自然汇合。"],
	["不应住色生心，不应住声香味触法生心。", "心不必被外界牵着走，净土先从不执着开始。", "城门之外，风吹幡动，人心却不跟着摇摆。"],
	["若福德有实，如来不说得福德多。", "福德越大，越不能把它抓成一个可炫耀的东西。", "星夜下满地灯盏，有一盏被悄悄放到路边。"],
	["当知是经义不可思议，果报亦不可思议。", "真正重要的法，需要被尊重、被受持，而不是被浅尝辄止。", "经卷被置于素净案上，檀香烟气缓慢上升。"],
	["应如是生清净心。", "清净心不是逃离生活，而是在生活中不被相绑住。", "雨后庭院，瓦檐滴水，行者把鞋摆正后入室。"],
	["离一切诸相，则名诸佛。", "离相不是否认世界，而是不让任何相替代真实。", "山间云雾散开，人物背影与远峰相互让出空间。"],
	["若有善男子、善女人，初日分以恒河沙等身布施。", "再大的外在付出，也比不上真正理解并转化一念执着。", "恒河沙岸，沙粒与星光连成一片，人物放下满篮珍宝。"],
	["先世罪业，则为消灭。", "业障被看见、被承受、被转化，心才真正轻下来。", "破旧墙面前，行者擦去尘土，露出温和的光。"],
	["实无有法，发阿耨多罗三藐三菩提心者。", "连“我在发心”也不能住，修行才不会变成新的自我包装。", "莲池边，合掌的人影倒映在水中又被涟漪散开。"],
	["如来有肉眼、天眼、慧眼、法眼、佛眼。", "看见不只是一种视觉，也是一种穿透分别的能力。", "五重圆窗望向同一片山河，每一层光色不同。"],
	["若心有住，则为非住。", "心一旦固定在某个结论上，就失去真正的自由。", "风翻书页，墨迹未干，窗外云影正在移动。"],
	["不可以色身见如来。", "不要把真实局限在可见的形体上。", "佛像只露出半身，真正的光落在空处与众人脸上。"],
	["说法者，无法可说，是名说法。", "最深的表达，常常不是占有真理，而是指向真理。", "讲法者指向月光，听者看见的不是手指。"],
	["于法实无所得。", "所谓得到，很多时候只是心又抓住了一个新对象。", "空钵放在石阶上，里面只有天空的倒影。"],
	["应无所住而生其心。", "这句是全经的心脏：进入世界做事，但不被世界黏住。", "市集中人来人往，一人提灯穿行，灯光不占有任何人。"],
	["若三千大千世界中所有诸须弥山王，如是等七宝聚，有人持用布施。", "智慧不是反对福德，而是让福德不再变成执着。", "宝塔与山河并置，塔光很亮，远处一卷经更安静。"],
	["实无有众生如来度者。", "帮助别人时，不把自己放在拯救者的位置。", "渡船到岸，船夫转身修补绳结，没有看向掌声。"],
	["若以三十二相观如来者，转轮圣王即是如来。", "看相容易，看见相背后的空性很难。", "华丽王冠置于桌上，旁边是一盏朴素油灯。"],
	["发阿耨多罗三藐三菩提心者，于法不说断灭相。", "不执着不是虚无；放下相，也不等于否定因果和善行。", "枯枝旁新芽冒出，冬雾里有很淡的春色。"],
	["菩萨所作福德，不应贪著。", "行善后不贪著，善才不会反过来占据心。", "布施后的空篮放在门口，主人已经走远。"],
	["如来者，无所从来，亦无所去，故名如来。", "真实不在来去之间，也不被时间和位置限制。", "长路尽头没有人影，只有晨雾在山门间流动。"],
	["一合相者，即是不可说。", "世界看似合成一个整体，但任何定义都无法把它说尽。", "碎瓦、树叶、流水、衣角在同一画面中自然相连。"],
	["不应生法相。", "连“我懂了”的知见也要放下，否则又成了新的相。", "读经者合上书，室内安静，窗外鸟影掠过。"],
	["一切有为法，如梦幻泡影，如露亦如电，应作如是观。", "结尾把全经收束为一种观看方式：认真活着，也知道一切流动不居。", "清晨露珠、闪电余光与水中泡影同框，行者在远处回身。"],
];

const secondCardSentences = [
	"尔时，世尊食时，著衣持钵，入舍卫大城乞食。",
	"汝今谛听！当为汝说：善男子、善女人，发阿耨多罗三藐三菩提心，应如是住，如是降伏其心。",
	"如是灭度无量无数无边众生，实无众生得灭度者。",
	"何以故？若菩萨不住相布施，其福德不可思量。",
	"不也，世尊！不可以身相得见如来。",
	"如来灭后，后五百岁，有持戒修福者，于此章句能生信心，以此为实。",
	"如来有所说法耶？须菩提言：如我解佛所说义，无有定法名阿耨多罗三藐三菩提，亦无有定法，如来可说。",
	"何以故？是福德即非福德性，是故如来说福德多。",
	"须陀洹名为入流，而无所入，不入色声香味触法，是名须陀洹。",
	"如来昔在然灯佛所，于法有所得不？",
	"是诸恒河沙宁为多不？须菩提言：甚多，世尊！",
	"须菩提！当知是人成就最上第一希有之法。",
	"是经名为《金刚般若波罗蜜》，以是名字，汝当奉持。",
	"佛说如是甚深经典，我从昔来所得慧眼，未曾得闻如是之经。",
	"须菩提！以要言之，是经有不可思议、不可称量、无边功德。",
	"以今世人轻贱故，先世罪业则为消灭，当得阿耨多罗三藐三菩提。",
	"善男子、善女人，发阿耨多罗三藐三菩提心，云何应住？云何降伏其心？",
	"过去心不可得，现在心不可得，未来心不可得。",
	"若福德有实，如来不说得福德多；以福德无故，如来说得福德多。",
	"如来不应以具足色身见。",
	"若人言：如来有所说法，即为谤佛，不能解我所说故。",
	"我于阿耨多罗三藐三菩提乃至无有少法可得。",
	"所言善法者，如来说即非善法，是名善法。",
	"若人以此《般若波罗蜜经》，乃至四句偈等，受持、为他人说，其福胜彼。",
	"若有众生如来度者，如来则有我、人、众生、寿者。",
	"若以色见我，以音声求我，是人行邪道，不能见如来。",
	"发阿耨多罗三藐三菩提心者，说诸法断灭。莫作是念！",
	"若复有人知一切法无我，得成于忍，此菩萨胜前菩萨所得功德。",
	"若有人言：如来若来若去、若坐若卧，是人不解我所说义。",
	"一合相者，则是不可说，但凡夫之人贪著其事。",
	"于一切法，应如是知，如是见，如是信解，不生法相。",
	"云何为人演说，不取于相，如如不动。",
];

const secondCardPlains = [
	"佛陀入城乞食、饭后洗足而坐，说明法从日常生活中展开。",
	"佛先让须菩提专心听，然后把“安住其心”的方法正式展开。",
	"真正度众生时，不把“我度了众生”抓成自己的功劳。",
	"不住相去布施，福德才不会被自我和回报心限制。",
];

const makePrompt = (visual: string, index: number) =>
	`16:9 Chinese ink watercolor Buddhist sutra illustration. Scene: ${visual} Composition panel ${index + 1}, quiet cinematic framing, ivory rice-paper texture, pale mineral washes, thin sepia line art, restrained gold and pine green accents. No readable writing, no captions, no logo, no watermark.`;

const imageForCard = (chapter: number, sentence: number) =>
	chapter <= 32 ? withBase(`/assets/jingangjing/c${String(chapter).padStart(2, "0")}-s${String(sentence).padStart(2, "0")}.png`) : "";

const chapters = chapterTitles.map((title, index) => {
	const [quote, plain, visual] = chapterNotes[index];
	const chapter = index + 1;
	return {
		chapter,
		title,
		gist: plain,
		text: quote,
		cards: [
			{
				id: `c${chapter}-s01`,
				sentence: quote,
				plain,
				image: imageForCard(chapter, 1),
				prompt: makePrompt(visual, index),
			},
			{
				id: `c${chapter}-s02`,
				sentence: secondCardSentences[index],
				plain: secondCardPlains[index] ?? `这一句承接「${title}」，继续把本品主题推向“不住相”的理解。`,
				image: imageForCard(chapter, 2),
				prompt: makePrompt(`${visual} A second quieter frame focused on hands, objects, and empty space.`, index),
			},
		],
	};
});

const sourceRanges = [
	[3, 4],
	[5, 7],
	[8, 8],
	[9, 14],
	[15, 17],
	[18, 21],
	[22, 23],
	[24, 26],
	[27, 34],
	[35, 41],
	[42, 46],
	[47, 47],
	[48, 56],
	[57, 62],
	[63, 65],
	[66, 68],
	[69, 77],
	[78, 92],
	[93, 95],
	[96, 99],
	[100, 102],
	[103, 104],
	[105, 105],
	[106, 106],
	[107, 107],
	[108, 113],
	[114, 115],
	[116, 118],
	[119, 119],
	[120, 122],
	[123, 125],
	[126, 128],
];

const sourceParagraphs = diamondSutraData.paragraphs;
const sourceChapters = chapters.map((chapter, index) => {
	const [start, end] = sourceRanges[index];
	const paragraphs = sourceParagraphs.filter((item) => item.position >= start && item.position <= end);
	return {
		...chapter,
		sourceStart: start,
		sourceEnd: end,
		sourceParagraphs: paragraphs.map((item) => ({
			...item,
			translation: item.translations?.find((translation) => translation.language === "zh-CN")?.translatedText ?? "",
		})),
	};
});
---

<html lang="zh-CN">
	<head>
		<MainHead
			title="金刚经配图版"
			description="把《金刚经》拆成逐品图文卡片：经文摘句、白话解释和水墨配图提示。"
			keywords="金刚经,配图版,佛经,图文阅读,水墨插画"
		/>
	</head>
	<body class="sutra-tool-body">
	<main class="sutra-reader" data-page-root>
		<header class="sutra-topbar">
			<a class="sutra-brand" href={withBase("/")} aria-label="返回首页">
				<span class="brand-mark" aria-hidden="true">
					<span class="brand-glyph">金</span>
					<span class="brand-line"></span>
				</span>
				<span>
					<span class="brand-eyebrow">Vajracchedika · Illustrated Reader</span>
					<strong>金刚经配图版</strong>
					<em>应无所住，而生其心</em>
				</span>
			</a>
			<div class="sutra-mantra" aria-hidden="true">
				<span>如露亦如电</span>
				<i></i>
				<span>应作如是观</span>
			</div>
			<nav class="reader-actions" aria-label="阅读操作">
				<button class="audio-toggle" type="button" data-audio-toggle aria-pressed="false" aria-label="播放诵读音频">
					<span class="audio-orb" aria-hidden="true">
						<span></span>
						<span></span>
						<span></span>
					</span>
					<span class="audio-copy">
						<strong data-audio-label>诵读</strong>
						<em data-audio-state>点击播放</em>
					</span>
				</button>
				<button class="reader-link source-toggle" type="button" data-source-toggle aria-pressed="false">原文来源</button>
				<a class="reader-link" href={repoUrl} target="_blank" rel="noreferrer">开源仓库</a>
			</nav>
			<audio data-sutra-audio preload="metadata">
				<source src={withBase("/assets/jingangjing/1009.mp3")} type="audio/mpeg" />
			</audio>
		</header>

		<div class="reader-shell">
			<aside class="chapter-rail" aria-label="三十二品目录">
				<div class="rail-title" data-rail-title>第 01 品 · 法会因由分</div>
				<div class="chapter-list">
					{chapters.map((chapter) => (
						<button class:list={["chapter-button", chapter.chapter === 1 && "active"]} type="button" data-chapter-target={chapter.chapter}>
							<span>{String(chapter.chapter).padStart(2, "0")}</span>
							<strong>{chapter.title}</strong>
						</button>
					))}
				</div>
			</aside>

			<section class="reading-pane" data-reader-view="cards" aria-live="polite">
				{chapters.map((chapter) => (
					<article class:list={["chapter-panel", chapter.chapter === 1 && "active"]} data-chapter-panel={chapter.chapter}>
						<header class="chapter-header">
							<div class="chapter-kicker">第 {chapter.chapter} 品</div>
							<div class="chapter-title-row">
								<h1>{chapter.title}</h1>
								<div class="chapter-stepper">
									<button class="step-button" type="button" data-move="-1" aria-label="上一品">‹</button>
									<select aria-label="选择品目" data-chapter-select>
										{chapters.map((item) => (
											<option value={item.chapter} selected={item.chapter === chapter.chapter}>
												{String(item.chapter).padStart(2, "0")} {item.title}
											</option>
										))}
									</select>
									<button class="step-button" type="button" data-move="1" aria-label="下一品">›</button>
								</div>
							</div>
							<p class="chapter-gist">{chapter.gist}</p>
							<p class="chapter-text">{chapter.text}</p>
						</header>

						<div class="manga-grid">
							{chapter.cards.map((card, cardIndex) => (
								<article class="manga-card" id={card.id}>
									<div class="panel-meta">
										<span>第 {chapter.chapter} 品</span>
										<strong>{String(cardIndex + 1).padStart(2, "0")}</strong>
									</div>
									<button
										class="comic-frame-button"
										type="button"
										data-open-card={card.id}
										data-chapter={chapter.chapter}
										data-index={cardIndex}
										data-title={`第 ${chapter.chapter} 品 · ${cardIndex + 1}/${chapter.cards.length}`}
										data-sentence={card.sentence}
										data-plain={card.plain}
										data-prompt={card.prompt}
										data-image={card.image}
										aria-label={`打开第 ${chapter.chapter} 品第 ${cardIndex + 1} 张配图`}
									>
										{card.image ? (
											<img
												class="comic-image"
												src={card.image}
												alt={`第 ${chapter.chapter} 品第 ${cardIndex + 1} 张配图：${card.sentence}`}
												loading={chapter.chapter === 1 ? "eager" : "lazy"}
											/>
										) : (
											<div class={`comic-fallback fallback-${cardIndex % 5}`} aria-label={card.prompt}>
												<span class="ink-sun"></span>
												<span class="ink-mountain one"></span>
												<span class="ink-mountain two"></span>
												<span class="ink-river"></span>
												<span class="ink-figure"></span>
												<span class="fallback-label">
													<span>配图提示词已生成</span>
													<strong>{chapter.chapter}.{cardIndex + 1}</strong>
												</span>
											</div>
										)}
									</button>
									<div class="dialogue">
										<p class="original">{card.sentence}</p>
										<p class="plain">{card.plain}</p>
									</div>
								</article>
							))}
						</div>
					</article>
				))}
			</section>

			<section class="source-pane" data-reader-view="source" aria-live="polite" hidden>
				{sourceChapters.map((chapter) => (
					<article class:list={["source-panel", chapter.chapter === 1 && "active"]} data-source-panel={chapter.chapter}>
						<header class="source-header">
							<div>
								<p class="source-eyebrow">原文对照 · 第 {String(chapter.chapter).padStart(2, "0")} 品</p>
								<h1>{chapter.title}</h1>
							</div>
							<div class="chapter-stepper source-stepper">
								<button class="step-button" type="button" data-move="-1" aria-label="上一品">‹</button>
								<select aria-label="选择品目" data-chapter-select>
									{chapters.map((item) => (
										<option value={item.chapter} selected={item.chapter === chapter.chapter}>
											{String(item.chapter).padStart(2, "0")} {item.title}
										</option>
									))}
								</select>
								<button class="step-button" type="button" data-move="1" aria-label="下一品">›</button>
							</div>
						</header>
						<div class="source-list">
							{chapter.sourceParagraphs.map((paragraph) => (
								<article class="source-pair">
									<div class="source-original-block">
