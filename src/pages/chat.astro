---
import MainHead from "../components/MainHead.astro";
import { withBase } from "../utils/paths";

const sampleQuestions = [
	"如何理解「应作如是观」？",
	"遇到执念时怎么安住其心？",
	"因果和放下矛盾吗？",
];

const originCodeLines = [
	"git init yingzuo-rushi",
	"echo \"把问题先放到桌面上\" >> README.md",
	"echo \"从经典里找一句能照见当下的话\" >> README.md",
	"echo \"不急着证明，只回到下一步\" >> README.md",
];

const originSections = [
	{
		title: "先从一个具体问题开始",
		paragraphs: [
			"我是文韬，长期和产品、界面、图像、文字打交道，也长期用阅读记录自己的变化。做「应作如是」，不是想把佛法做成一个标准答案机器，而是想留一个安静的工作台：当一个问题把人卡住，先把问题说清楚，再从经文里找一束光，最后回到今天能做的事。",
			"对我来说，读《金刚经》不是逃离现实，而是让现实少一点把人拖走。工作、关系、情绪、成败都还在，只是心不必每一次都被它们拽着跑。",
		],
	},
	{
		title: "设计不是装饰，是降低靠近的门槛",
		paragraphs: [
			"很多时候，人不是缺道理，而是缺一个能让自己停下来、看清楚的入口。古文、注释、白话、问答，如果排得太重，就会把原本想靠近的人挡在外面。",
			"所以这个工具会尽量克制：少一点说教，少一点神秘感，少一点「我来告诉你答案」。把经文、解释和你的问题放在一个干净界面里，让你自己慢慢看见。",
		],
	},
	{
		title: "AI 只是把散落的东西重新排好",
		paragraphs: [
			"AI 在这里不是老师，也不是判官。它做的事很朴素：从本地知识库里找相关经文和解释，把散开的材料整理成一段可以读下去的话。",
			"真正重要的不是它说得多漂亮，而是这段话能不能帮你少一点反应、多一点判断。能不能让你从「我怎么会这样」往后退一步，问出更有效的「下一步是什么」。",
		],
	},
	{
		title: "愿它有一点实际用处",
		paragraphs: [
			"我希望「应作如是」保留一点手作感：像一张读书卡片，也像一次深夜里的自问自答。它不替你决定人生，也不替你证明谁对谁错。",
			"如果它能在某个很乱的时刻，让你把心放稳一点，把事情看清一点，把行动往前推一点，就够了。经典不必只在书页里，它也可以落在今天的一个小选择里。",
		],
	},
];
---

<html lang="zh-CN">
	<head>
		<MainHead
			title="应作如是 · 如是我问"
			description="围绕佛法、人生与心念的问答页面。"
			keywords="应作如是,如是我问,佛法问答,金刚经"
			favicon={withBase("/assets/brand/favicon.png")}
		/>
		<link rel="preconnect" href="https://fontsapi.zeoseven.com" crossorigin />
		<link rel="preconnect" href="https://registry.npmmirror.com" crossorigin />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://unpkg.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500&display=swap" />
		<link rel="stylesheet" href="https://registry.npmmirror.com/lxgw-wenkai-screen-web/1.521.0/files/lxgwwenkaiscreen/result.css" />
		<link rel="stylesheet" href="https://unpkg.com/@chinese-fonts/hwmct@3.0.0/dist/%E6%B1%87%E6%96%87%E6%98%8E%E6%9C%9D%E4%BD%93/result.css" />
		<script is:inline>
			(() => {
				const key = "yingzuo-chat-theme";
				let theme = "";
				try {
					const saved = localStorage.getItem(key);
					if (saved === "dark" || saved === "light") theme = saved;
				} catch {
					theme = "";
				}
				if (!theme) {
					theme = window.matchMedia?.("(prefers-color-scheme: dark)")?.matches ? "dark" : "light";
				}
				document.documentElement.classList.toggle("theme-dark", theme === "dark");
			})();
		</script>
	</head>
	<body class="ask-body">
		<div class="ask-page" data-chat-page>
			<header class="ask-topbar" aria-label="主导航">
				<a class="brand" href={withBase("/")} aria-label="应作如是首页">
					<img class="brand-mark" src={withBase("/assets/brand/yingzuo-logo.png")} alt="" aria-hidden="true" loading="eager" />
					<span class="brand-copy">
						<strong>应作如是</strong>
						<em>观心问答</em>
					</span>
				</a>

				<nav class="nav-tabs" aria-label="模块导航">
					<button class="nav-item active" type="button" aria-current="page" data-view-target="chat">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6.5A3.5 3.5 0 0 1 8.5 3h7A3.5 3.5 0 0 1 19 6.5v4a3.5 3.5 0 0 1-3.5 3.5H11l-5 4v-4.2A3.5 3.5 0 0 1 5 11.5Z" /></svg>
						<span>如是我问</span>
					</button>
					<button class="nav-item" type="button">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
						<span>随缘读经</span>
					</button>
					<button class="nav-item" type="button" data-view-target="origin">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v18M8 7h8M7 11h10M9 15h6" /></svg>
						<span>缘起</span>
					</button>
				</nav>

				<div class="toolbar" aria-label="页面工具">
					<label class="search-box">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.35-4.35M10.8 18a7.2 7.2 0 1 1 0-14.4 7.2 7.2 0 0 1 0 14.4Z" /></svg>
						<input type="search" placeholder="搜索经句或问题" />
						<kbd>⌘ K</kbd>
					</label>
					<button class="icon-button" type="button" aria-label="日历">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3v4M17 3v4M4.5 9h15M6 5h12a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" /></svg>
					</button>
					<button class="icon-button theme-button" type="button" aria-label="切换明暗" aria-pressed="false" data-theme-toggle>
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v2.2M12 18.8V21M4.2 4.2l1.6 1.6M18.2 18.2l1.6 1.6M3 12h2.2M18.8 12H21M4.2 19.8l1.6-1.6M18.2 5.8l1.6-1.6M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" /></svg>
					</button>
					<button class="profile-button" type="button" aria-label="个人中心">
						<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM4.5 20a7.5 7.5 0 0 1 15 0" /></svg>
					</button>
				</div>
			</header>

			<main class="chat-shell app-view" data-view-panel="chat">
				<section class="chat-scroll" data-chat-scroll>
					<section class="hero" aria-labelledby="page-title">
						<h1 id="page-title">应作如是</h1>
						<p class="subhead">收录 <span class="subhead-number">30</span> 部佛经与古文典籍，你所问的关于佛法、人生、心念的一切，皆有经典可依的回答</p>
					</section>

					<section class="conversation" aria-label="问答示例" data-conversation>
						<div class="prompt-row">
							<button class="prompt-card" type="button" data-question={sampleQuestions[0]} data-current-question>
								<span data-current-question-text>{sampleQuestions[0]}</span>
							</button>
							<span class="question-badge" aria-hidden="true">问</span>
						</div>

						<article class="answer-row">
							<div class="answer-avatar" aria-hidden="true">
								<span>观</span>
							</div>
							<div class="answer-card" data-answer-card>
								<p>「应作如是观」不是让人冷漠地否定世界，而是提醒我们：眼前的一切都在因缘中生起，也会在因缘中变化。</p>
								<p>所以面对顺境，不必把它抓成永恒；面对困境，也不用把它认成终局。能看见事物的流动性，心就少一点被外相牵走。</p>
								<p>放到日常里，就是认真做该做的事，但不让结果占据全部的心。看见、承受、行动，然后给变化留下空间。</p>
							</div>
						</article>

						<div class="answer-actions" aria-label="回答操作">
							<button type="button" aria-label="复制">
								<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8h10v10H8zM6 16H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" /></svg>
							</button>
							<button type="button" aria-label="分享">
								<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 16V4M7 9l5-5 5 5M5 14v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4" /></svg>
							</button>
							<button type="button" aria-label="赞同">
								<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 11v9M7 11H4v9h3M7 11l4-7a2 2 0 0 1 3 1.8V9h4a2 2 0 0 1 1.9 2.5l-1.4 6A2 2 0 0 1 16.6 19H7" /></svg>
							</button>
							<button type="button" aria-label="不赞同">
								<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 13V4M7 13H4V4h3M7 13l4 7a2 2 0 0 0 3-1.8V15h4a2 2 0 0 0 1.9-2.5l-1.4-6A2 2 0 0 0 16.6 5H7" /></svg>
							</button>
						</div>
					</section>
				</section>

				<section class="composer-panel" aria-label="提问输入">
					<div class="quick-questions" aria-label="推荐问题">
						{sampleQuestions.map((question) => (
							<button type="button" data-question={question}>{question}</button>
						))}
					</div>

					<form class="composer" data-composer>
						<div class="composer-tools" aria-label="输入工具">
							<button type="button" aria-label="历史问题">
								<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7M3 4v5h5M12 7v5l3 2" /></svg>
							</button>
							<button type="button" aria-label="新问题">
								<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
							</button>
							<button type="button" aria-label="导入文本">
								<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12M7 10l5 5 5-5M5 21h14" /></svg>
							</button>
						</div>
						<label class="composer-input">
							<textarea name="question" rows="3" placeholder="提出您的问题..." data-question-input></textarea>
						</label>
						<button class="send-button" type="submit" aria-label="发送问题">
							<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 12H7M12 7l-5 5 5 5" /></svg>
						</button>
					</form>
					<p class="disclaimer">回答基于知识库生成，仅供参考。复杂问题请咨询专业人士。</p>
				</section>
			</main>

			<section class="origin-shell app-view" data-view-panel="origin" hidden aria-labelledby="origin-title">
				<div class="origin-hero">
					<div class="origin-mark" aria-hidden="true">
						<svg viewBox="0 0 24 24"><path d="M12 20V9M8 13c-3 0-5-2-5-5 3 0 5 2 5 5Zm8 0c3 0 5-2 5-5-3 0-5 2-5 5ZM8 13h8M12 9c0-3 2-5 5-5 0 3-2 5-5 5Z" /></svg>
					</div>
					<p class="origin-eyebrow">ORIGIN</p>
					<h1 id="origin-title">缘起</h1>
					<p>把读经、设计和日常困惑放在同一张桌上，慢慢问，也慢慢照见自己。</p>
				</div>

				<div class="origin-divider" aria-hidden="true"></div>

				<pre class="origin-code" aria-label="项目缘起代码片段"><code>{originCodeLines.join("\n")}</code></pre>

				<article class="origin-article">
					{originSections.map((section) => (
						<section class="origin-section">
							<h2>{section.title}</h2>
							{section.paragraphs.map((paragraph) => (
								<p>{paragraph}</p>
							))}
						</section>
					))}
				</article>
			</section>
		</div>

		<script>
			import { answerFromKnowledge } from "../lib/knowledge";

			const page = document.querySelector("[data-chat-page]");
			const input = page?.querySelector("[data-question-input]");
			const initialAnswerCard = page?.querySelector("[data-answer-card]");
			const conversation = page?.querySelector("[data-conversation]");
			const chatScroll = page?.querySelector("[data-chat-scroll]");
			const composer = page?.querySelector("[data-composer]");
			const questionButtons = page?.querySelectorAll("[data-question]");
			const sendButton = page?.querySelector(".send-button");
			const currentQuestion = page?.querySelector("[data-current-question]");
			const currentQuestionText = page?.querySelector("[data-current-question-text]");
			const themeButton = page?.querySelector("[data-theme-toggle]");
			const viewButtons = page?.querySelectorAll("[data-view-target]");
			const viewPanels = page?.querySelectorAll("[data-view-panel]");
			let activeAnswerCard = initialAnswerCard;
			const storageKey = "yingzuo-chat-session";
			const themeStorageKey = "yingzuo-chat-theme";

			type Citation = {
				scriptureTitle: string;
				position: number;
				originalText: string;
			};

			type ChatResult = {
				answer?: string;
				quote?: {
					source: string;
					text: string;
					translation?: string;
				};
				interpretation?: string;
				citations?: Citation[];
			};

			type StoredTurn = {
				question: string;
				result: ChatResult;
			};

			let conversationHistory: StoredTurn[] = [];

			function appendParagraph(container: Element, text: string) {
				const paragraph = document.createElement("p");
				paragraph.textContent = text;
				container.append(paragraph);
			}

			function isRemovedNotice(line: string) {
				return line.includes("本地知识库") && line.includes("网页搜索") && line.includes("依据");
			}

			function answerLines(text: string) {
				return String(text)
					.split(/\n{2,}/)
					.map((line) => line.trim())
					.filter((line) => line && !isRemovedNotice(line));
			}

			function scrollAnswerToEnd(target = activeAnswerCard) {
				if (!conversation || !target) return;
				requestAnimationFrame(() => {
					const scrollContainer = chatScroll instanceof HTMLElement ? chatScroll : conversation;
					scrollContainer.scrollTo({ top: scrollContainer.scrollHeight, behavior: "smooth" });
					const lastContent = target.lastElementChild;
					if (lastContent instanceof HTMLElement) {
						lastContent.scrollIntoView({ behavior: "smooth", block: "end", inline: "nearest" });
					}
				});
			}

			function renderAnswer(answer: string, citations: Citation[] = [], target = activeAnswerCard) {
				if (!target) return;
				target.innerHTML = "";

				answerLines(answer).forEach((line) => appendParagraph(target, line));

				if (!citations.length) return;

				const citationList = document.createElement("div");
				citationList.className = "citation-list";
				const title = document.createElement("strong");
				title.textContent = "引用依据";
				citationList.append(title);

				citations.forEach((citation) => {
					const item = document.createElement("div");
					item.className = "citation-item";
					const source = document.createElement("span");
					source.textContent = `《${citation.scriptureTitle}》第 ${citation.position} 段`;
					const quote = document.createElement("q");
					quote.textContent = citation.originalText;
					item.append(source, quote);
					citationList.append(item);
				});

				target.append(citationList);
			}

			function renderKnowledgeResult(result: ChatResult, target = activeAnswerCard) {
				if (!target) return;
				target.innerHTML = "";

				if (result.quote) {
					const quoteBlock = document.createElement("figure");
					quoteBlock.className = "answer-quote";
					const quote = document.createElement("blockquote");
					quote.textContent = result.quote.text;
					const caption = document.createElement("figcaption");
					caption.textContent = result.quote.source;
					quoteBlock.append(quote, caption);

					if (result.quote.translation) {
						const translation = document.createElement("p");
						translation.className = "quote-translation";
						translation.textContent = result.quote.translation;
						quoteBlock.append(translation);
					}

					target.append(quoteBlock);
				}

				const interpretation = document.createElement("section");
				interpretation.className = "answer-interpretation";
				const heading = document.createElement("h2");
				heading.textContent = "解析";
				interpretation.append(heading);

				answerLines(result.interpretation || result.answer || "").forEach((line) => appendParagraph(interpretation, line));

				target.append(interpretation);

				const restCitations = (result.citations ?? []).slice(1);
				if (restCitations.length) {
					const citationList = document.createElement("div");
					citationList.className = "citation-list compact";
					const title = document.createElement("strong");
					title.textContent = "相关依据";
					citationList.append(title);

					restCitations.forEach((citation) => {
						const item = document.createElement("div");
						item.className = "citation-item";
						const source = document.createElement("span");
						source.textContent = `《${citation.scriptureTitle}》第 ${citation.position} 段`;
						const quote = document.createElement("q");
						quote.textContent = citation.originalText;
						item.append(source, quote);
						citationList.append(item);
					});

					target.append(citationList);
				}
			}

			function createConversationTurn(question: string) {
				if (!conversation) return null;

				const turn = document.createElement("div");
				turn.className = "conversation-turn";

				const promptRow = document.createElement("div");
				promptRow.className = "prompt-row";
				const promptCard = document.createElement("button");
				promptCard.className = "prompt-card";
				promptCard.type = "button";
				promptCard.setAttribute("data-question", question);
				const promptText = document.createElement("span");
				promptText.textContent = question;
				promptCard.append(promptText);
				const badge = document.createElement("span");
				badge.className = "question-badge";
				badge.setAttribute("aria-hidden", "true");
				badge.textContent = "问";
				promptRow.append(promptCard, badge);

				const answerRow = document.createElement("article");
				answerRow.className = "answer-row";
				const avatar = document.createElement("div");
				avatar.className = "answer-avatar";
				avatar.setAttribute("aria-hidden", "true");
				const avatarText = document.createElement("span");
				avatarText.textContent = "观";
				avatar.append(avatarText);
				const card = document.createElement("div");
				card.className = "answer-card";
				answerRow.append(avatar, card);

				turn.append(promptRow, answerRow);
				conversation.append(turn);
				return card;
			}

			function saveSession() {
				try {
					sessionStorage.setItem(storageKey, JSON.stringify(conversationHistory.slice(-20)));
				} catch {
					// Ignore private browsing or storage quota failures.
				}
			}

			function restoreSession() {
				if (!conversation) return;
				try {
					const raw = sessionStorage.getItem(storageKey);
					if (!raw) return;
					const saved = JSON.parse(raw);
					if (!Array.isArray(saved) || !saved.length) return;
					conversationHistory = saved.filter((item) => item?.question && item?.result).slice(-20);
					if (!conversationHistory.length) return;
					conversation.innerHTML = "";
					conversationHistory.forEach((turn) => {
						const card = createConversationTurn(turn.question);
						renderKnowledgeResult(turn.result, card);
					});
				} catch {
					conversationHistory = [];
				}
			}

			function updateCurrentQuestion(question: string) {
				if (currentQuestion instanceof HTMLButtonElement) {
					currentQuestion.setAttribute("data-question", question);
				}
				if (currentQuestionText) {
					currentQuestionText.textContent = question;
				}
			}

			function wait(ms: number) {
				return new Promise((resolve) => window.setTimeout(resolve, ms));
			}

			function flattenStoredTurn(turn: StoredTurn) {
				const quote = turn.result?.quote?.text ?? "";
				const answer = turn.result?.interpretation ?? turn.result?.answer ?? "";
				return [turn.question, quote, answer].filter(Boolean).join(" ");
			}

			function submitQuestion() {
				if (composer instanceof HTMLFormElement) {
					composer.requestSubmit();
				}
			}

			function applyTheme(theme: "light" | "dark") {
				const isDark = theme === "dark";
				document.documentElement.classList.toggle("theme-dark", isDark);
				document.body.classList.toggle("theme-dark", isDark);
				if (themeButton instanceof HTMLButtonElement) {
					themeButton.setAttribute("aria-pressed", String(isDark));
					themeButton.setAttribute("aria-label", isDark ? "切换浅色" : "切换暗黑");
				}
			}

			function getInitialTheme() {
				try {
					const saved = localStorage.getItem(themeStorageKey);
					if (saved === "dark" || saved === "light") return saved;
				} catch {
					// Keep the default when storage is unavailable.
				}
				return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
			}

			applyTheme(getInitialTheme());

			function persistTheme(theme: "light" | "dark") {
				try {
					localStorage.setItem(themeStorageKey, theme);
				} catch {
					// Ignore storage failures.
				}
			}

			function animateThemeSwitch(nextTheme: "light" | "dark") {
				if (!(themeButton instanceof HTMLButtonElement)) {
					applyTheme(nextTheme);
					persistTheme(nextTheme);
					return;
				}

				const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
				const supportsViewTransition = "startViewTransition" in document;
				const rect = themeButton.getBoundingClientRect();
				const x = rect.left + rect.width / 2;
				const y = rect.top + rect.height / 2;

				document.documentElement.style.setProperty("--theme-x", `${x}px`);
				document.documentElement.style.setProperty("--theme-y", `${y}px`);
				document.documentElement.classList.add("theme-is-switching");

				const finish = () => {
					persistTheme(nextTheme);
					window.setTimeout(() => {
						document.documentElement.classList.remove("theme-is-switching");
					}, 120);
				};

				if (!supportsViewTransition || prefersReducedMotion) {
					applyTheme(nextTheme);
					finish();
					return;
				}

				const transition = document.startViewTransition(() => applyTheme(nextTheme));
				transition.ready
					.then(() => {
						const endRadius = Math.hypot(
							Math.max(x, window.innerWidth - x),
							Math.max(y, window.innerHeight - y),
						);
						document.documentElement.animate(
							{
								clipPath: [
									`circle(0px at ${x}px ${y}px)`,
									`circle(${endRadius}px at ${x}px ${y}px)`,
								],
							},
							{
								duration: 760,
								easing: "cubic-bezier(0.22, 1, 0.36, 1)",
								pseudoElement: "::view-transition-new(root)",
							},
						);
					})
					.finally(finish);
			}

			themeButton?.addEventListener("click", () => {
				const nextTheme = document.body.classList.contains("theme-dark") ? "light" : "dark";
				animateThemeSwitch(nextTheme);
			});

			function setView(viewName: string) {
				viewPanels?.forEach((panel) => {
					if (!(panel instanceof HTMLElement)) return;
					panel.hidden = panel.getAttribute("data-view-panel") !== viewName;
				});
				viewButtons?.forEach((button) => {
					if (!(button instanceof HTMLElement)) return;
					const isActive = button.getAttribute("data-view-target") === viewName;
					button.classList.toggle("active", isActive);
					if (isActive) {
						button.setAttribute("aria-current", "page");
					} else {
						button.removeAttribute("aria-current");
					}
				});
			}

			viewButtons?.forEach((button) => {
				button.addEventListener("click", () => {
					const viewName = button.getAttribute("data-view-target");
					if (!viewName) return;
					setView(viewName);
				});
			});

			questionButtons?.forEach((button) => {
				button.addEventListener("click", () => {
					if (!(input instanceof HTMLTextAreaElement)) return;
					input.value = button.getAttribute("data-question") ?? "";
					input.focus();
				});
			});

			input?.addEventListener("keydown", (event) => {
				if (!(input instanceof HTMLTextAreaElement)) return;
				if (!(event instanceof KeyboardEvent)) return;
				if (event.key !== "Enter" || event.shiftKey || event.isComposing) return;
				event.preventDefault();
				submitQuestion();
			});

			restoreSession();

			composer?.addEventListener("submit", async (event) => {
				event.preventDefault();
				if (!(input instanceof HTMLTextAreaElement)) return;
				const question = input.value.trim();
				if (!question) {
					input.focus();
					return;
				}
				updateCurrentQuestion(question);
				const turnAnswerCard = createConversationTurn(question);
				activeAnswerCard = turnAnswerCard;
				turnAnswerCard?.setAttribute("aria-busy", "true");
				renderAnswer(`正在从本地知识库检索：「${question}」`, [], turnAnswerCard);
				if (sendButton instanceof HTMLButtonElement) sendButton.disabled = true;

				try {
					await wait(320);
					const historyText = conversationHistory.slice(-6).map(flattenStoredTurn).filter(Boolean).join(" ");
					const result = answerFromKnowledge(question, [historyText, question].filter(Boolean).join(" "));

					renderKnowledgeResult(result, turnAnswerCard);
					conversationHistory.push({ question, result });
					saveSession();
					input.value = "";
					scrollAnswerToEnd(turnAnswerCard);
				} catch {
					renderAnswer("本地知识库暂时没有返回结果。请换一个更具体的问题再试。", [], turnAnswerCard);
					scrollAnswerToEnd(turnAnswerCard);
				} finally {
					turnAnswerCard?.removeAttribute("aria-busy");
					if (sendButton instanceof HTMLButtonElement) sendButton.disabled = false;
				}
			});
		</script>
	</body>
